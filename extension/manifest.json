{
  "manifest_version": 3,
  "name": "VirusTotal URL Scanner",
  "version": "1.0.0",
  "description": "Scan the current tab's URL with VirusTotal and display a Safe / Suspicious / Malicious verdict.",
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": ["https://www.virustotal.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VirusTotal URL Scanner",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}